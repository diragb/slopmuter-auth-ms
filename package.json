{
  "name": "slopmuter-auth-ms",
  "version": "0.1.0",
  "description": "Authentication microservice for SlopMuter, a browser extension that filters AI-generated slop and low-effort content from X/Twitter feeds.",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/server.js",
    "dev": "tsx --watch src/server.ts",
    "create:test:refresh": "node scripts/create-test-refresh-token.js",
    "db:start": "docker compose up -d postgres",
    "db:stop": "docker compose down",
    "db:shell": "docker exec -it auth-service-postgres psql -U postgres -d auth_service",
    "migrate": "node scripts/run-migration.js"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "type": "commonjs",
  "dependencies": {
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "pg": "^8.20.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/cors": "^2",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9",
    "@types/node": "^25.5.0",
    "@types/pg": "^8",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
